{
  "name": "firstgame",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
